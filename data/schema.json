{
  "csv": {
    "path": "data/dataset.csv",
    "columns": {
      "inventory": "Car Inventory Data",
      "pricing": "Pricing Details"
    },
    "format": "json-in-cells"
  },
  "assets": {
    "placeholder_image": "assets/placeholder.png"
  },
  "match_score": {
    "scale": "0-100",
    "weights": {
      "budget": 0.5,
      "intent": 0.3,
      "lifestyle_family": 0.2
    },
    "display_cutoff": 50,
    "use_provided_total_when_available": true
  },
  "finance": {
    "default_source": "per_car_pricing_details",
    "disclaimer": "All finance figures are examples only and subject to approval. No credit check is performed in this demo."
  },
  "recommendations": {
    "min_required_inputs": ["intent", "monthly_budget"],
    "initial_count": { "min": 1, "max": 3 },
    "within_turns": 3,
    "within_turns_policy": "acceptance"
  },
  "updates": {
    "debounce_ms": 300,
    "when_no_results": "suggest_relaxations",
    "shortlist_persistence": "persist_with_no_longer_fits_flag"
  }
}
