OPENAI_API_KEY=your_openai_api_key_here

# Example: local VS Code run (not used by Docker Compose)
# Adjust to your local Postgres or use Docker Compose defaults in .env.docker
DATABASE_URL=postgresql+psycopg://postgres:postgres@localhost:5432/mktplace
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=mktplace
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres

# Frontend-to-backend for local runs
BACKEND_HOST=localhost
BACKEND_PORT=8000

# App ports for local run
FASTAPI_HOST=127.0.0.1
FASTAPI_PORT=8000
STREAMLIT_HOST=127.0.0.1
STREAMLIT_PORT=8501

# Data paths
INVENTORY_CSV_PATH=data/dataset.csv
PLACEHOLDER_IMAGE_PATH=assets/placeholder.svg

# Optional Chroma (Python client, not server). Disabled by default.
CHROMA_ENABLED=false
CHROMA_DB_PATH=./vector_db